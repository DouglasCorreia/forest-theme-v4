{
  "name": "projeto-tailwind-v4",
  "version": "1.0.0",
  "description": "Projeto de conclusão de curso do tailwind utilizando a versão 4",
  "main": "tailwind.config.js",
  "scripts": {
    "tailwind": "tailwindcss -i ./src/assets/css/input.css -o ./src/assets/css/output.css --watch",
    "tailwind:prod": "tailwindcss -i ./src/assets/css/input.css -o ./src/assets/css/output.css --watch --minify"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.1",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/typography": "^0.5.19"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@tailwindcss/postcss": "^4.1.14",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.1",
    "postcss": "^8.4.47",
    "tailwindcss": "^4.1.14"
  }
}
